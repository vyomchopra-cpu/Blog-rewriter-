{
  "name": "blog-generator",
  "version": "1.0.0",
  "main": "src/main/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build && electron-builder",
    "start": "electron .",
    "serve": "node server/server.js",
    "serve:build": "vite build && node server/server.js"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "electron-store": "^8.2.0",
    "express": "^4.22.2",
    "mammoth": "^1.6.0",
    "pdf-parse": "^1.1.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^8.0.0",
    "electron": "^28.0.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.4.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.0.0",
    "tailwindcss": "^3.4.0",
    "vite": "^5.0.0",
    "vite-plugin-electron": "^0.15.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.moveinsync.blog-generator",
    "productName": "Blog Generator",
    "files": [
      "dist/**/*",
      "src/main/**/*",
      "src/data/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "portable",
        "dir"
      ]
    },
    "mac": {
      "target": [
        "dir"
      ],
      "identity": null,
      "category": "public.app-category.productivity"
    },
    "portable": {
      "artifactName": "BlogGenerator-Portable-${version}.exe"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
